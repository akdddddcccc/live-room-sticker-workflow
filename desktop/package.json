{
  "name": "ai-live-room-sticker-desktop",
  "version": "0.1.9",
  "private": true,
  "main": "main.cjs",
  "scripts": {
    "dev": "electron .",
    "pack": "electron-builder --win portable",
    "pack:mac": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "cn.muyang.live-room-sticker-workflow",
    "productName": "AI直播间贴片生成项目",
    "files": [
      "main.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../dist",
        "to": "dist"
      },
      {
        "from": "../scripts",
        "to": "scripts"
      },
      {
        "from": "../docs",
        "to": "docs"
      },
      {
        "from": "../.env.local.example",
        "to": ".env.local.example"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ]
    },
    "mac": {
      "icon": "build/icon.png",
      "target": [
        "dmg"
      ]
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.35.1"
  }
}
